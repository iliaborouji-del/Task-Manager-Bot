# Bot tokens
TOKEN=YOUR_TELEGRAM_OR_BALE_TOKEN

# API bases
API_BASE=https://api.telegram.org or https://api.bale.ai
BALE_CHAT_BASE=https://web.bale.ai/chat?uid=YOUR_BALE_UID

# QR API
QR_API_URL=https://api.qrserver.com/v1/create-qr-code

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security
QR_SECRET=YOUR_SECRET_KEY